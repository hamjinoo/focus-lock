{
  "manifest_version": 3,
  "name": "focus-lock",
  "version": "0.1.0",
  "description": "Belt-and-suspenders block at the Chrome layer. Talks to the local focus-lock service. Works under DNS-over-HTTPS where the hosts file does not.",
  "permissions": ["declarativeNetRequest", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "focus-lock",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "incognito": "spanning"
}
